# syntax = docker/dockerfile:1.11-labs

FROM input AS source

ADD --link . /usr/src/tuwunel


# source-rust: the compile-relevant subset of source. The cargo build stages
# copy from this allowlist so commits touching only docs, workflows, or other
# non-build files keep their cache keys and do not rebuild the workspace.
FROM scratch AS source-rust

WORKDIR /usr/src/tuwunel
COPY --link --from=source /usr/src/tuwunel/.cargo .cargo
COPY --link --from=source /usr/src/tuwunel/Cargo.toml Cargo.toml
COPY --link --from=source /usr/src/tuwunel/Cargo.lock Cargo.lock
COPY --link --from=source /usr/src/tuwunel/clippy.toml clippy.toml
COPY --link --from=source /usr/src/tuwunel/rust-toolchain.toml rust-toolchain.toml
COPY --link --from=source /usr/src/tuwunel/tuwunel-example.toml tuwunel-example.toml
COPY --link --from=source /usr/src/tuwunel/src src


FROM input AS ingredients
ARG rust_target
ARG rust_toolchain
ARG RUST_HOME
ARG RUSTUP_HOME
ARG CARGO_HOME
ARG CARGO_TARGET
ARG CARGO_TERM_VERBOSE=0
ARG RUST_BACKTRACE
ARG JEMALLOC_OVERRIDE
ARG ROCKSDB_LIB_DIR
ARG ROCKSDB_INCLUDE_DIR
ARG sched_policy="--rr"
ARG sched_prio=1

WORKDIR /
COPY --link --from=rust ${RUST_HOME} ${RUST_HOME}
COPY --link --from=source /usr/src/tuwunel /usr/src/tuwunel

WORKDIR /usr/src/tuwunel
ENV PATH="${CARGO_HOME}/bin:$PATH"
ENV CARGO_TERM_VERBOSE="${CARGO_TERM_VERBOSE}"
ENV RUST_BACKTRACE="${RUST_BACKTRACE}"
ENV JEMALLOC_OVERRIDE="${JEMALLOC_OVERRIDE}"
ENV ROCKSDB_LIB_DIR="${ROCKSDB_LIB_DIR}"
ENV ROCKSDB_INCLUDE_DIR="${ROCKSDB_INCLUDE_DIR}"
ENV sched_policy=${sched_policy}
ENV sched_prio=${sched_prio}
RUN \
--mount=type=cache,dst=${RUSTUP_HOME}/downloads,sharing=locked \
--mount=type=cache,dst=${CARGO_HOME}/registry,sharing=locked \
--mount=type=cache,dst=${CARGO_HOME}/git,sharing=locked \
<<EOF
    set -eux
    rustup run ${rust_toolchain} sched_wrap.sh \
        cargo fetch \
            --locked \
            --target ${CARGO_TARGET}
EOF


FROM input AS preparing
ARG rust_target
ARG rust_toolchain
ARG RUSTUP_HOME
ARG CARGO_HOME
ARG CARGO_TARGET
ARG sched_policy="--rr"
ARG sched_prio=1

WORKDIR /usr/src/tuwunel
ENV sched_policy=${sched_policy}
ENV sched_prio=${sched_prio}
RUN \
--mount=type=cache,dst=${RUSTUP_HOME}/downloads,sharing=locked \
--mount=type=cache,dst=${CARGO_HOME}/registry,sharing=locked \
--mount=type=cache,dst=${CARGO_HOME}/git,sharing=locked \
<<EOF
    set -euxo pipefail
    rustup run ${rust_toolchain} sched_wrap.sh \
        cargo chef prepare \
            --recipe-path recipe.json

    #TODO: derive from `cargo tree -f {r} -p rust-librocksdb-sys`
    echo "https://github.com/matrix-construct/rust-rocksdb" > rocksdb.url

    sha1sum recipe.json rocksdb.url
EOF


FROM scratch AS recipe

WORKDIR /
COPY --link --from=preparing /usr/src/tuwunel/recipe.json .
COPY --link --from=preparing /usr/src/tuwunel/rocksdb.url .
