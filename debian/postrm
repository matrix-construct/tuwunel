#!/bin/sh
set -e

#. /usr/share/debconf/confmodule

TUWUNEL_DATABASE_PATH=/var/lib/tuwunel

case $1 in
  purge)
    # The database and anything else under /var/lib/tuwunel are never
    # deleted, even on purge; remove that directory manually if that is
    # really intended. Only the compatibility symlinks are cleaned up.
    for link in /var/lib/matrix-conduit /var/lib/conduwuit; do
      if [ -L "$link" ] && [ "$(readlink -f "$link")" = "$TUWUNEL_DATABASE_PATH" ]; then
        rm -v "$link"
      fi
    done

    if [ -e "$TUWUNEL_DATABASE_PATH" ]; then
      echo "Preserving the database at $TUWUNEL_DATABASE_PATH" 1>&2
    fi
    ;;
esac

#DEBHELPER#
